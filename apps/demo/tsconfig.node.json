{
  "include": ["vite.config.*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "lib": ["ESNext"],
    "types": ["node"],

    "target": "ES2020",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  }
}
