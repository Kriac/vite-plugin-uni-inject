{
  "easycom": {
    "autoscan": false,
    "custom": {
      "^t-(.*)": "@tdesign/uniapp/$1/$1.vue"
    }
  },
  "globalStyle": {
    "backgroundColor": "#fafafa",
    "navigationStyle": "custom",
    "navigationBarTextStyle": "black"
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "disableScroll": true
      }
    },
    {
      "path": "modules/example/pages/test"
    }
  ],
  "subPackages": [
    {
      "root": "sub-packages/tutorial",
      "pages": [
        {
          "path": "views/index"
        }
      ]
    }
  ]
}
